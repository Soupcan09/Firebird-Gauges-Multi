# --- ESP-IDF build artifacts ----------------------------------------
# The build/ folder is regenerated by `idf.py build`. Never commit it.
build/
managed_components/
dependencies.lock

# Old sdkconfig snapshots created by menuconfig
sdkconfig.old
sdkconfig.ci

# Compiled binaries / debug output that sometimes lands at project root
*.bin
*.elf
*.map
*.hex
*.out

# --- Editor / IDE -------------------------------------------------
# Keep .vscode/ for shared settings, but drop personal/ephemeral bits.
.vscode/ipch/
.vscode/.browse.*
.vscode/c_cpp_properties.json.bak
*.code-workspace

# CLion / Eclipse / others
.idea/
.cproject
.project
.settings/

# --- OS junk ------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# --- Python (for render_gauge.py + any helper scripts) -----------
__pycache__/
*.pyc
*.pyo
venv/
.venv/
env/

# --- Misc ---------------------------------------------------------
*.log
*.swp
*.swo
*~

# --- OTA secrets --------------------------------------------------
# WiFi credentials and OTA server URL live in ota_config.h, which is
# NEVER committed.  Copy ota_config.h.example -> ota_config.h and
# fill in your local network details.
main/OTA/ota_config.h

# --- OTA serving directory ---------------------------------------
# scripts/serve_firmware.py drops the latest binary here for HTTP
# pickup.  Not source code -- regenerated on every server start.
serve/

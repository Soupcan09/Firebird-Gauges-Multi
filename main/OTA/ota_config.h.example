/*
 * ota_config.h.example -- TEMPLATE for OTA configuration.
 *
 * Copy this file to ota_config.h (in the same directory) and fill in
 * your local WiFi credentials + firmware server URL.  ota_config.h is
 * gitignored so your credentials never leave your machine.
 *
 *     cp main/OTA/ota_config.h.example main/OTA/ota_config.h
 *     # then edit main/OTA/ota_config.h and put your real SSID/pass in
 *
 * The build will fail with a clear message if ota_config.h is missing.
 */
#ifndef OTA_CONFIG_H
#define OTA_CONFIG_H

/* ------------------------------------------------------------------ */
/* WiFi credentials                                                    */
/* ------------------------------------------------------------------ */
/* SSID and password of the WiFi network the gauge should connect to
 * when checking for updates. Both gauges connect to the same SSID. */
#define OTA_WIFI_SSID       "YourHomeWiFi"
#define OTA_WIFI_PASSWORD   "YourWiFiPassword"

/* ------------------------------------------------------------------ */
/* Firmware server URL                                                 */
/* ------------------------------------------------------------------ */
/* HTTP URL of the firmware binary to download.  Example for a PC
 * running `python -m http.server 8000` from the build/ directory:
 *
 *     http://192.168.1.42:8000/ESP32-S3-Touch-LCD-2.1.bin
 *
 * Replace 192.168.1.42 with your PC's actual local IP (Windows:
 * 'ipconfig'; Linux/Mac: 'ifconfig' or 'ip addr').  Filename matches
 * whatever the ESP-IDF build produces -- usually the project name
 * with .bin extension.
 *
 * HTTPS (esp_https_ota) is supported too if you want it; just change
 * the URL and provide a server cert.  HTTP is fine for trusted home
 * networks. */
#define OTA_FIRMWARE_URL    "http://192.168.1.42:8000/firmware.bin"

/* ------------------------------------------------------------------ */
/* Timing                                                              */
/* ------------------------------------------------------------------ */
/* How long (ms) to wait for WiFi to associate before giving up. */
#define OTA_WIFI_CONNECT_TIMEOUT_MS  15000

/* HTTP request timeout for the firmware download (ms).  Big firmware
 * + slow WiFi can take 60+ seconds. */
#define OTA_HTTP_TIMEOUT_MS          120000

#endif /* OTA_CONFIG_H */
